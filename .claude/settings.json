{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check_file_access.py",
            "statusMessage": "Checking file access..."
          }
        ]
      }
    ]
  }
}
